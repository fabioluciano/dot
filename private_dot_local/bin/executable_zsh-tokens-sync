#!/usr/bin/env bash
set -euo pipefail
# Resolve API tokens from the Bitwarden item "dotfiles-tokens" ONCE and write
# them as ready-to-source `export` lines into ~/.config/zsh/tokens.zsh (mode
# 600), which ~/.zshenv sources. This keeps secrets out of the git repo and out
# of every shell's startup path (no `bw`/`python` at shell init).
#
# Run this manually whenever a token rotates. It is also invoked automatically
# by the chezmoi run_onchange script on apply. Gracefully no-ops (keeping any
# existing tokens file) when `bw` is missing or the vault is locked.

OUT="${XDG_CONFIG_HOME:-$HOME/.config}/zsh/tokens.zsh"
ITEM="dotfiles-tokens"

# Bitwarden custom-field name  ->  exported environment variable
MAP=(
  "github_token=GITHUB_TOKEN"
  "gitlab_token=GITLAB_TOKEN"
  "bitbucket_token=BITBUCKET_TOKEN"
  "jira_token=JIRA_TOKEN"
  "jira_email=JIRA_EMAIL"
  "jira_domain=JIRA_DOMAIN"
  "work_mail=WORK_MAIL"
  "claude_api_key=ANTHROPIC_API_KEY"
  "bedrock_api_key=AWS_BEARER_TOKEN_BEDROCK"
  "mimo_api_key=MIMO_API_KEY"
)

command -v bw >/dev/null 2>&1 || { echo "zsh-tokens-sync: bw nao instalado; pulando." >&2; exit 0; }
bw unlock --check >/dev/null 2>&1 || { echo "zsh-tokens-sync: vault bloqueado; mantendo tokens atuais." >&2; exit 0; }

item_json="$(bw get item "$ITEM" 2>/dev/null)" || {
  echo "zsh-tokens-sync: item '$ITEM' nao encontrado." >&2; exit 0;
}

# Parse every custom field once into "name<TAB>value" lines.
if command -v jq >/dev/null 2>&1; then
  fields="$(printf '%s' "$item_json" | jq -r '.fields[]? | "\(.name)\t\(.value // "")"')"
else
  fields="$(printf '%s' "$item_json" | python3 -c 'import sys, json
d = json.load(sys.stdin)
for f in d.get("fields", []):
    print((f.get("name") or "") + "\t" + (f.get("value") or ""))')"
fi

# POSIX single-quote escaping so the value is safe to source in zsh/bash.
# (Substitution done in an assignment — inside double quotes the backslashes
# would be taken literally and the escaping would break.)
sq() { local s=${1//\'/\'\\\'\'}; printf "'%s'" "$s"; }

mkdir -p "$(dirname "$OUT")"
umask 077
tmp="$(mktemp)"
{
  echo "# Generated by zsh-tokens-sync — DO NOT edit, DO NOT commit."
  echo "# Secrets resolved from Bitwarden item '$ITEM'."
  for pair in "${MAP[@]}"; do
    field="${pair%%=*}"; var="${pair#*=}"
    val="$(printf '%s\n' "$fields" | awk -F'\t' -v k="$field" '$1==k{print $2; exit}')"
    [ -n "$val" ] && printf 'export %s=%s\n' "$var" "$(sq "$val")"
  done
} > "$tmp"
chmod 600 "$tmp"
mv "$tmp" "$OUT"
echo "zsh-tokens-sync: $OUT atualizado."
