#!/usr/bin/env bash
set -euo pipefail
# Alterna o provider do OpenCode para todos os agentes.
# Escreve o provider ativo em ~/.config/opencode/.active_provider e re-renderiza
# oh-my-openagent.json via chezmoi apply.
# Uso: oc-provider <provider> [profile]

PROVIDERS=(bedrock-claude bedrock-mixed anthropic xiaomi openai github-copilot opencode opencode-free google bifrost)
PROFILES=(optimized moderate super ultra recommended)
############################################
# Normalization and backward-compatibility
############################################
PROVIDER="${1:-}"
if [ -z "$PROVIDER" ]; then
  echo "Uso: $(basename "$0") <provider> [profile]"
  exit 1
fi

# Normalize profile input
# If no profile or only provider is supplied, default to moderate
if [ "$#" -lt 2 ]; then
  PROFILE_TARGET="moderate"
else
  INPUT_PROFILE="$2"
  case "$INPUT_PROFILE" in
    optimized|moderate|super|ultra|recommended)
      PROFILE_TARGET="$INPUT_PROFILE"
      ;;
    default)
      # backward-compat: map legacy -default to moderate
      PROFILE_TARGET="moderate"
      ;;
    *)
      echo "Perfil inválido: $INPUT_PROFILE. Perfis válidos: optimized, moderate, super, ultra, recommended."
      exit 1
      ;;
  esac
  fi
PROFILE="$PROFILE_TARGET"

# Ensure the runtime 'profile' variable (used by the rest of the script) defaults
# to moderate when no explicit profile argument is provided.
if [ "$#" -lt 2 ]; then
  profile="moderate"
else
  profile="${2}"
fi
STATE_FILE="${HOME}/.config/opencode/.active_provider"

usage() {
  cat >&2 <<EOF
Uso: oc-provider <provider> [profile]

Providers disponíveis: ${PROVIDERS[*]}
Profiles disponíveis: ${PROFILES[*]} (padrão: moderate)

Exemplo:
oc-provider bedrock-claude       # Bedrock Claude (profile moderate por padrão)
oc-provider bedrock-claude optimized    # Bedrock Claude com profile optimized
oc-provider bedrock-mixed       # Bedrock mixed (profile moderate por padrão)
oc-provider bedrock-mixed optimized    # Bedrock mixed com profile optimized
oc-provider bedrock-claude super        # Bedrock Claude com profile super
oc-provider bedrock-claude ultra        # Bedrock Claude com profile ultra
oc-provider bedrock-claude moderate     # Bedrock Claude com profile moderate
oc-provider bedrock-claude recommended  # Bedrock Claude com tiers recomendados pelo Oh My OpenAgent
oc-provider github-copilot       # GitHub Copilot Plus (profile moderate por padrão)
oc-provider xiaomi               # xiaomi (profile moderate por padrão)
oc-provider opencode             # opencode (profile moderate por padrão)
oc-provider google               # google (profile moderate por padrão)
EOF
  exit 1
}

# --- Validação dos argumentos ---
if [[ $# -lt 1 || $# -gt 2 ]]; then
  echo "Erro: número de argumentos inválido." >&2
  usage
fi

provider="$1"
if [ -z "${2:-}" ]; then
  profile="moderate"
else
  profile="$2"
fi

# Valida provider
valid=false
for p in "${PROVIDERS[@]}"; do
  if [[ "$p" == "$provider" ]]; then
    valid=true
    break
  fi
done

if [[ "$valid" != true ]]; then
  echo "Erro: provider inválido '$provider'." >&2
  echo "Providers válidos: ${PROVIDERS[*]}" >&2
  exit 1
fi

# Valida profile
valid=false
for p in "${PROFILES[@]}"; do
  if [[ "$p" == "$profile" ]]; then
    valid=true
    break
  fi
done

if [[ "$valid" != true ]]; then
  echo "Erro: profile inválido '$profile'." >&2
  echo "Profiles válidos: ${PROFILES[*]}" >&2
  exit 1
fi

# --- Persiste o estado ---
mkdir -p "$(dirname "$STATE_FILE")"
cat > "$STATE_FILE" <<EOF
provider:${provider}
profile:${profile}
EOF

# --- Re-renderiza oh-my-openagent.json via chezmoi ---
chezmoi apply ~/.config/opencode/oh-my-openagent.jsonc

echo ""
echo "✓ Provider ativo: ${provider}"
echo "✓ Profile ativo: ${profile}"
  echo "  Arquivo de estado: ${STATE_FILE}"
  echo "  oh-my-openagent.jsonc atualizado via chezmoi."
  echo ""
  echo "Perfis disponíveis:"
  echo "  optimized  - Economia de ~28% (medium para tarefas rotineiras, high para críticas)"
  echo "  moderate   - Alias para optimized"
  echo "  recommended - Tiers recomendados pelo Oh My OpenAgent para cada papel/modelo"
  echo "  super      - Economia máxima de ~38% (low/medium para maioria, high apenas para ultrabrain)"
  echo "  ultra      - Custo mínimo: menor esforço suportado, provider decide onde não há variant segura"
