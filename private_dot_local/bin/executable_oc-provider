#!/usr/bin/env bash
set -euo pipefail

PROVIDERS=(bedrock-claude bedrock-mixed anthropic xiaomi openai github-copilot opencode opencode-free google bifrost)
PROFILES=(optimized moderate super ultra recommended)
DEFAULT_PROVIDER="xiaomi"
DEFAULT_PROFILE="moderate"
STATE_FILE="${HOME}/.config/opencode/.active_provider"
TARGET_FILE="${HOME}/.config/opencode/oh-my-openagent.jsonc"

usage() {
  cat >&2 <<EOF
Uso:
  $(basename "$0") <provider> [profile]
  $(basename "$0") dry-run <provider> [profile]
  $(basename "$0") status
  $(basename "$0") reset

Providers disponíveis: ${PROVIDERS[*]}
Profiles disponíveis: ${PROFILES[*]} (padrão: ${DEFAULT_PROFILE})
EOF
  exit 1
}

is_valid_provider() {
  local candidate=$1
  local provider
  for provider in "${PROVIDERS[@]}"; do
    [[ "$provider" == "$candidate" ]] && return 0
  done
  return 1
}

normalize_profile() {
  local input=${1:-$DEFAULT_PROFILE}
  if [[ "$input" == "default" ]]; then
    echo "$DEFAULT_PROFILE"
    return 0
  fi

  local profile
  for profile in "${PROFILES[@]}"; do
    if [[ "$profile" == "$input" ]]; then
      echo "$profile"
      return 0
    fi
  done

  echo "Perfil inválido: $input. Perfis válidos: ${PROFILES[*]}." >&2
  exit 1
}

read_state() {
  if [[ ! -f "$STATE_FILE" ]]; then
    printf 'provider:%s\nprofile:%s\n' "$DEFAULT_PROVIDER" "$DEFAULT_PROFILE"
    return 0
  fi

  cat "$STATE_FILE"
}

print_status() {
  local state provider profile
  state=$(read_state)
  provider=$(printf '%s\n' "$state" | awk -F: '/^provider:/{print $2}')
  profile=$(printf '%s\n' "$state" | awk -F: '/^profile:/{print $2}')

  provider=${provider:-$DEFAULT_PROVIDER}
  profile=${profile:-$DEFAULT_PROFILE}

  echo "Provider ativo: $provider"
  echo "Profile ativo: $profile"
  echo "Arquivo de estado: $STATE_FILE"
  echo "Target renderizado: $TARGET_FILE"
}

write_state() {
  local provider=$1 profile=$2
  mkdir -p "$(dirname "$STATE_FILE")"
  cat > "$STATE_FILE" <<EOF
provider:${provider}
profile:${profile}
EOF
}

apply_target() {
  chezmoi apply "$TARGET_FILE"
}

if [[ $# -lt 1 || $# -gt 3 ]]; then
  usage
fi

command_name=$1

case "$command_name" in
  status)
    [[ $# -eq 1 ]] || usage
    print_status
    exit 0
    ;;
  reset)
    [[ $# -eq 1 ]] || usage
    write_state "$DEFAULT_PROVIDER" "$DEFAULT_PROFILE"
    apply_target
    print_status
    exit 0
    ;;
  dry-run)
    [[ $# -ge 2 && $# -le 3 ]] || usage
    provider=$2
    profile=$(normalize_profile "${3:-$DEFAULT_PROFILE}")
    is_valid_provider "$provider" || {
      echo "Erro: provider inválido '$provider'." >&2
      echo "Providers válidos: ${PROVIDERS[*]}" >&2
      exit 1
    }

    echo "Dry run"
    echo "Provider alvo: $provider"
    echo "Profile alvo: $profile"
    echo "Arquivo de estado: $STATE_FILE"
    echo "Target renderizado: $TARGET_FILE"
    exit 0
    ;;
esac

provider=$1
profile=$(normalize_profile "${2:-$DEFAULT_PROFILE}")

is_valid_provider "$provider" || {
  echo "Erro: provider inválido '$provider'." >&2
  echo "Providers válidos: ${PROVIDERS[*]}" >&2
  exit 1
}

write_state "$provider" "$profile"
apply_target
print_status
