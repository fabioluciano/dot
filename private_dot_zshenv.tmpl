# Environment variables - Generated by chezmoi
# DO NOT EDIT MANUALLY - Edit private_dot_zshenv.tmpl instead

# mise shims — garante as versoes gerenciadas pelo mise tambem em shells
# NAO-interativos, scripts e processos que dao spawn em zsh. O `mise activate`
# no .zshrc cobre apenas o shell interativo; os shims cobrem o resto.
[[ -d "$HOME/.local/share/mise/shims" ]] && export PATH="$HOME/.local/share/mise/shims:$PATH"

# API Tokens
# Uses existing env vars when available, falls back to Bitwarden otherwise
{{- $bw := false -}}
{{- if not (env "GITHUB_TOKEN") }}{{ $bw = true }}{{ end }}

{{- if $bw -}}
{{- $fields := bitwardenFields "item" "dotfiles-tokens" }}
{{- with $fields.github_token }}
export GITHUB_TOKEN="{{ .value }}"{{ end }}
{{- with $fields.gitlab_token }}
export GITLAB_TOKEN="{{ .value }}"{{ end }}
{{- with $fields.bitbucket_token }}
export BITBUCKET_TOKEN="{{ .value }}"{{ end }}
{{- with $fields.jira_token }}
export JIRA_TOKEN="{{ .value }}"{{ end }}
{{- with $fields.jira_email }}
export JIRA_EMAIL="{{ .value }}"{{ end }}
{{- with $fields.jira_domain }}
export JIRA_DOMAIN="{{ .value }}"{{ end }}
{{- with $fields.work_mail }}
export WORK_MAIL="{{ .value }}"{{ end }}
{{- with $fields.anthropic_api_key }}
export ANTHROPIC_API_KEY="{{ .value }}"{{ end }}
{{- with $fields.openai_api_key }}
export OPENAI_API_KEY="{{ .value }}"{{ end }}
{{- with $fields.google_api_key }}
export GOOGLE_API_KEY="{{ .value }}"{{ end }}
{{- with $fields.perplexity_api_key }}
export PERPLEXITY_API_KEY="{{ .value }}"{{ end }}
{{- with $fields.openrouter_api_key }}
export OPENROUTER_API_KEY="{{ .value }}"{{ end }}
{{- with $fields.groq_api_key }}
export GROQ_API_KEY="{{ .value }}"{{ end }}
{{- with $fields.mistral_api_key }}
export MISTRAL_API_KEY="{{ .value }}"{{ end }}
{{- with $fields.xai_api_key }}
export XAI_API_KEY="{{ .value }}"{{ end }}
{{- else }}
export GITHUB_TOKEN="{{ env "GITHUB_TOKEN" }}"
export GITLAB_TOKEN="{{ env "GITLAB_TOKEN" }}"
export BITBUCKET_TOKEN="{{ env "BITBUCKET_TOKEN" }}"
export JIRA_TOKEN="{{ env "JIRA_TOKEN" }}"
export JIRA_EMAIL="{{ env "JIRA_EMAIL" }}"
export JIRA_DOMAIN="{{ env "JIRA_DOMAIN" }}"
export WORK_MAIL="{{ env "WORK_MAIL" }}"
{{- end }}
