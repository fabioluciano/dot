# Environment variables - Generated by chezmoi
# DO NOT EDIT MANUALLY - Edit private_dot_zshenv.tmpl instead

# mise shims — garante as versoes gerenciadas pelo mise tambem em shells
# NAO-interativos, scripts e processos que dao spawn em zsh. O `mise activate`
# no .zshrc cobre apenas o shell interativo; os shims cobrem o resto.
[[ -d "$HOME/.local/share/mise/shims" ]] && export PATH="$HOME/.local/share/mise/shims:$PATH"

# API Tokens
# Uses existing env vars when available, falls back to Bitwarden otherwise.
# Graceful fallback: a locked Bitwarden vault does NOT abort shell startup.

{{- $hasEnv := (env "GITHUB_TOKEN") }}
{{- if $hasEnv }}

# Tokens already in environment — export directly
export GITHUB_TOKEN="{{ env "GITHUB_TOKEN" }}"
{{- with env "GITLAB_TOKEN" }}
export GITLAB_TOKEN="{{ . }}"{{ end }}
{{- with env "BITBUCKET_TOKEN" }}
export BITBUCKET_TOKEN="{{ . }}"{{ end }}
{{- with env "JIRA_TOKEN" }}
export JIRA_TOKEN="{{ . }}"{{ end }}
{{- with env "JIRA_EMAIL" }}
export JIRA_EMAIL="{{ . }}"{{ end }}
{{- with env "JIRA_DOMAIN" }}
export JIRA_DOMAIN="{{ . }}"{{ end }}
{{- with env "WORK_MAIL" }}
export WORK_MAIL="{{ . }}"{{ end }}
{{- with env "ANTHROPIC_API_KEY" }}
export ANTHROPIC_API_KEY="{{ . }}"{{ end }}
{{- with env "AWS_BEARER_TOKEN_BEDROCK" }}
export AWS_BEARER_TOKEN_BEDROCK="{{ . }}"{{ end }}
{{- with env "MIMO_API_KEY" }}
export MIMO_API_KEY="{{ . }}"{{ end }}

{{- else }}

# No tokens in environment — try Bitwarden at runtime (graceful fallback)
_zshenv_bw_warned=""
_zshenv_warn() {
  [ -z "$_zshenv_bw_warned" ] && _zshenv_bw_warned=1 \
    && echo "[zshenv] Warning: some API tokens not set (Bitwarden vault locked?)." >&2
}

_zshenv_bw_cache=""
_zshenv_bw_get() {
  # Fetches a single field from Bitwarden item "dotfiles-tokens".
  # Caches the item to avoid repeated bw calls. Returns empty on any failure.
  if [ -z "$_zshenv_bw_cache" ]; then
    command -v bw &>/dev/null || return 0
    bw unlock --check &>/dev/null 2>&1 || return 0
    _zshenv_bw_cache=$(bw get item "dotfiles-tokens" 2>/dev/null) || return 0
  fi
  [ -z "$_zshenv_bw_cache" ] && return 0
  printf '%s' "$_zshenv_bw_cache" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    fields = {f['name']: f.get('value','') for f in d.get('fields', [])}
    print(fields.get(sys.argv[1], ''), end='')
except Exception:
    pass
" "$1" 2>/dev/null
}

# GITHUB_TOKEN
_val=$(_zshenv_bw_get "github_token")
export GITHUB_TOKEN="${_val:-}"
[ -z "$_val" ] && _zshenv_warn

# GITLAB_TOKEN
_val=$(_zshenv_bw_get "gitlab_token")
export GITLAB_TOKEN="${_val:-}"
[ -z "$_val" ] && _zshenv_warn

# BITBUCKET_TOKEN
_val=$(_zshenv_bw_get "bitbucket_token")
export BITBUCKET_TOKEN="${_val:-}"
[ -z "$_val" ] && _zshenv_warn

# JIRA_TOKEN
_val=$(_zshenv_bw_get "jira_token")
export JIRA_TOKEN="${_val:-}"
[ -z "$_val" ] && _zshenv_warn

# JIRA_EMAIL
_val=$(_zshenv_bw_get "jira_email")
export JIRA_EMAIL="${_val:-}"
[ -z "$_val" ] && _zshenv_warn

# JIRA_DOMAIN
_val=$(_zshenv_bw_get "jira_domain")
export JIRA_DOMAIN="${_val:-}"
[ -z "$_val" ] && _zshenv_warn

# WORK_MAIL
_val=$(_zshenv_bw_get "work_mail")
export WORK_MAIL="${_val:-}"
[ -z "$_val" ] && _zshenv_warn

# ANTHROPIC_API_KEY
_val=$(_zshenv_bw_get "claude_api_key")
export ANTHROPIC_API_KEY="${_val:-}"
[ -z "$_val" ] && _zshenv_warn

# AWS_BEARER_TOKEN_BEDROCK
_val=$(_zshenv_bw_get "bedrock_api_key")
export AWS_BEARER_TOKEN_BEDROCK="${_val:-}"
[ -z "$_val" ] && _zshenv_warn

# MIMO_API_KEY
_val=$(_zshenv_bw_get "mimo_api_key")
export MIMO_API_KEY="${_val:-}"
[ -z "$_val" ] && _zshenv_warn

unset -f _zshenv_bw_get _zshenv_warn
unset _zshenv_bw_cache _zshenv_bw_warned _val

{{- end }}
