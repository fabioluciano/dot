# Environment variables - Generated by chezmoi
# DO NOT EDIT MANUALLY - Edit private_dot_zshenv.tmpl instead

# mise shims — garante as versoes gerenciadas pelo mise tambem em shells
# NAO-interativos, scripts e processos que dao spawn em zsh. O `mise activate`
# no .zshrc cobre apenas o shell interativo; os shims cobrem o resto.
[[ -d "$HOME/.local/share/mise/shims" ]] && export PATH="$HOME/.local/share/mise/shims:$PATH"

# API tokens
# Resolved once from Bitwarden by `zsh-tokens-sync` into the file below
# (secrets stay in the vault, never in this repo). Sourcing a pre-rendered file
# keeps every shell startup instant — no `bw`/`python` at runtime. If the file
# is absent (vault never synced, or CI) any tokens already in the environment
# are used as-is. Refresh after rotating a token with:  zsh-tokens-sync
_zsh_tokens="${XDG_CONFIG_HOME:-$HOME/.config}/zsh/tokens.zsh"
[ -r "$_zsh_tokens" ] && source "$_zsh_tokens"
unset _zsh_tokens
