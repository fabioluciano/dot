symbolPreset: nerd
theme:
  dark: dark-tokyo-night
  light: dark-tokyo-night
setupVersion: 1
modelRoles:
  default: xiaomi-token-plan-sgp/mimo-v2.5-pro
  smol: xiaomi-token-plan-sgp/mimo-v2.5
  slow: xiaomi-token-plan-sgp/mimo-v2.5-pro
  plan: xiaomi-token-plan-sgp/mimo-v2.5-pro
defaultThinkingLevel: auto
task:
  showResolvedModelBadge: true
  disabledAgents: []
  enableLsp: true
  softRequestBudget: 90
compaction:
  strategy: snapcompact
  reserveTokens: 16384
  keepRecentTokens: 20000
  supersedeReads: true
  dropUseless: true
retry:
  modelFallback: true
  fallbackRevertPolicy: cooldown-expiry
model:
  loopGuard:
    enabled: true
    checkAssistantContent: true
    toolCallReminder: true
power:
  sleepPrevention: active
proseOnlyThinking: true
statusLine:
  preset: nerd
  separator: slash
  sessionAccent: true
  transparent: false
  compactThinkingLevel: false
  showHookStatus: true
terminal:
  showProgress: true
tui:
  tight: false
  textSizing: true
display:
  shimmer: classic
  showTokenUsage: true
images:
  blockImages: true
memory:
  backend: mnemopi
bash:
  autoBackground:
    enabled: true
bashInterceptor:
  enabled: true
vault:
  enabled: true
github:
  enabled: true
mcp:
  discoveryMode: true
  notifications: true
dev:
  autoqa: true
