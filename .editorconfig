root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{sh,bash,zsh}]
indent_size = 4

[*.sh.tmpl]
indent_style = space
indent_size = 4

[*.lua]
indent_size = 2

[*.{toml,tmpl}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
