{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
# Re-run whenever ~/.Brewfile changes.
# Brewfile hash: {{ include "dot_Brewfile" | sha256sum }}
set -euo pipefail

command -v brew >/dev/null 2>&1 || exit 0

echo ":: brew bundle (Brewfile changed)"
brew_output=$(brew bundle --global 2>&1) && brew_exit=0 || brew_exit=$?
echo "$brew_output"
if [[ $brew_exit -ne 0 ]]; then
    echo ":: brew bundle failed (exit $brew_exit)" >&2
    exit "$brew_exit"
fi
if echo "$brew_output" | grep -qiE '(Error|Failed|error:)'; then
    echo ":: brew bundle reported errors in output" >&2
    exit 1
fi
{{- end -}}
