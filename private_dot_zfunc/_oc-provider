#compdef oc-provider

local -a commands providers profiles

commands=(
  'status:mostrar provider/profile atuais'
  'reset:restaurar provider/profile padrão'
  'dry-run:mostrar mudança sem aplicar'
)

providers=(
  'bedrock-claude:Bedrock Claude (Anthropic via AWS)'
  'bedrock-mixed:Bedrock mixed (non-Anthropic via AWS)'
  'anthropic:Anthropic direto'
  'xiaomi:Xiaomi (mimo)'
  'openai:OpenAI'
  'github-copilot:GitHub Copilot Plus'
  'opencode:OpenCode Zen'
  'opencode-free:OpenCode Zen (modelos gratuitos)'
  'google:Google'
  'bifrost:Bifrost (auto-routing)'
)

profiles=(
  'optimized:Economia de ~28% (medium para rotineiras, high para críticas)'
  'moderate:Alias para optimized'
  'super:Economia máxima de ~38% (low/medium para maioria)'
  'ultra:Custo mínimo: menor esforço suportado'
  'recommended:Tiers recomendados pelo Oh My OpenAgent'
)

if (( CURRENT == 2 )); then
  _alternative \
    'commands:command:((commands))' \
    'providers:provider:((providers))'
  return
fi

case "${words[2]-}" in
  status|reset)
    return
    ;;
  dry-run)
    if (( CURRENT == 3 )); then
      _describe 'provider' providers
    elif (( CURRENT == 4 )); then
      _describe 'profile' profiles
    fi
    return
    ;;
  *)
    if (( CURRENT == 3 )); then
      _describe 'profile' profiles
    fi
    ;;
esac
