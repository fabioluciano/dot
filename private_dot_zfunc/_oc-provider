#compdef oc-provider

local -a providers profiles
providers=(bedrock-claude bedrock-mixed anthropic xiaomi openai github-copilot opencode opencode-free google)
profiles=(optimized moderate super ultra recommended)

case "$CURRENT" in
  2)
    _describe 'provider' providers
    ;;
  3)
    _describe 'profile' profiles
    ;;
  *)
    _files
    ;;
esac
