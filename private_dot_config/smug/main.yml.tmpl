session: main
root: ~/

windows:
  - name: system

  - name: develop
    root: ~/developer
    panes:
      - type: horizontal
        commands:
          - nvim

  - name: monitoring
    commands:
      - btop
{{- if eq .chezmoi.os "linux" }}
    panes:
      - type: horizontal
        commands:
          - nvtop
{{- end }}
