{{- $defaultProvider := get $.opencode "default_provider" | default "xiaomi" -}}
{{- $stateFile := printf "%s/.config/opencode/.active_provider" (env "HOME") -}}
{{- $state := output "sh" "-c" (printf "cat %s 2>/dev/null || { echo provider:%s; echo profile:default; }" $stateFile $defaultProvider) | trim -}}
{{- $provider := "xiaomi" -}}
{{- $profile := "moderate" -}}
{{- if hasPrefix "provider:" $state -}}
{{- range $line := splitList "\n" $state }}
{{- $parts := splitList ":" $line -}}
{{- if eq (first $parts) "provider" }}{{- $provider = last $parts -}}{{- end -}}
{{- if eq (first $parts) "profile" }}{{- $profile = last $parts -}}{{- end -}}
{{- end -}}
{{- else -}}
{{- $provider = $state -}}
{{- $profile = "moderate" -}}
{{- end -}}
{{- if eq $provider "bedrock" -}}{{- $provider = "bedrock-claude" -}}{{- end -}}
{{- $validProviders := list "bedrock-claude" "bedrock-mixed" "xiaomi" "openai" "github-copilot" "opencode" "opencode-free" "anthropic" "google" "bifrost" -}}
{{- if not (has $provider $validProviders) -}}{{- $provider = $defaultProvider -}}{{- end -}}
{{- $providerModels := index $.opencode.models $provider -}}
{{- $variantProvider := $provider -}}
{{- if eq $provider "bedrock" -}}{{- $variantProvider = "bedrock-claude" -}}{{- end -}}
{{- $variantKey := printf "%s-%s" $variantProvider $profile -}}
{{- $providerVariants := ternary (get $.opencode.variants $variantKey) (get $.opencode.variants $variantProvider | default dict) (hasKey $.opencode.variants $variantKey) -}}
{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 3,
    "max_members": 6,
    "tmux_visualization": true,
    "max_wall_clock_minutes": 45
  },
  "agents": {
{{- $agents := keys $.opencode.agent_profiles | sortAlpha }}
{{- range $i, $agent := $agents }}
{{- $profile := index $.opencode.agent_profiles $agent }}
{{- $chain := index $providerModels $profile | default (index $providerModels "moderate") }}
{{- $primary := first $chain }}
{{- $variantValue := get $providerVariants $profile }}
    "{{ $agent }}": {
      "model": "{{ $primary }}",
      "fallback_models": [{{ range $j, $m := rest $chain }}{{ if $j }}, {{ end }}{"model": "{{ $m }}"}{{ end }}]
{{- if $variantValue }}
      ,"variant": "{{ $variantValue }}"
{{- end }}
      ,"prompt_append": "file://~/.config/opencode/AGENTS.md"
{{- $ultraworkProfile := get $.opencode.agent_ultrawork_profiles $agent }}
{{- if $ultraworkProfile }}
{{- $ultraworkChain := index $providerModels $ultraworkProfile | default (index $providerModels "moderate") }}
{{- $ultraworkVariant := get $providerVariants $ultraworkProfile }}
      ,"ultrawork": {
        "model": "{{ first $ultraworkChain }}",
        "fallback_models": [{{ range $j, $m := rest $ultraworkChain }}{{ if $j }}, {{ end }}{"model": "{{ $m }}"}{{ end }}]{{ if $ultraworkVariant }},
        "variant": "{{ $ultraworkVariant }}"{{ end }}
      }
{{- end }}
{{- if or (eq $agent "explore") (eq $agent "librarian") (eq $agent "multimodal-looker") }}
      ,"permission": {
        "edit": "deny"{{ if eq $agent "explore" }},
        "bash": "ask"{{ end }}
      }
{{- end }}
    }{{ if lt $i (sub (len $agents) 1) }},{{ end }}
{{- end }}
  },
  "categories": {
{{- $categories := keys $.opencode.category_profiles | sortAlpha }}
{{- range $i, $cat := $categories }}
{{- $profile := index $.opencode.category_profiles $cat }}
{{- $chain := index $providerModels $profile | default (index $providerModels "moderate") }}
{{- $primary := first $chain }}
{{- $variantValue := get $providerVariants $profile }}
    "{{ $cat }}": {
      "model": "{{ $primary }}",
      "fallback_models": [{{ range $j, $m := rest $chain }}{{ if $j }}, {{ end }}{"model": "{{ $m }}"}{{ end }}]
{{- if $variantValue }}
      ,"variant": "{{ $variantValue }}"
{{- end }}
      ,"prompt_append": "file://~/.config/opencode/AGENTS.md"
    }{{ if lt $i (sub (len $categories) 1) }},{{ end }}
{{- end }}
  },
  "experimental": {
    "disable_omo_env": true,
    "task_system": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "protected_tools": ["task", "todowrite", "todoread", "lsp_rename", "session_read", "session_write", "session_search"],
      "turn_protection": {"enabled": true, "turns": 2}
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [429, 500, 502, 503, 504],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "notify_on_fallback": true
  },
  "notification": {
    "force_enable": true
  }
}
