{{- $provider := output "sh" "-c" "cat \"$HOME/.config/opencode/.active_provider\" 2>/dev/null || echo bedrock" | trim -}}
{{- $validProviders := list "bedrock" "xiaomi" -}}
{{- if not (has $provider $validProviders) -}}{{- $provider = "bedrock" -}}{{- end -}}
{{- $tierOrder := list "pro" "fast" "cheap" -}}
{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 3,
    "max_members": 6,
    "tmux_visualization": true,
    "max_wall_clock_minutes": 90
  },
  "agents": {
{{- $agents := keys $.opencode.agent_tiers | sortAlpha }}
{{- range $i, $agent := $agents }}
{{- $tier := index $.opencode.agent_tiers $agent }}
{{- $primary := index (index $.opencode.tiers $provider) $tier }}
{{- $seen := list $primary }}
{{- $fallbacks := list }}
{{- range $t := $tierOrder }}
{{- if ne $t $tier }}
{{- $m := index (index $.opencode.tiers $provider) $t }}
{{- if not (has $m $seen) }}
{{- $seen = append $seen $m }}
{{- $fallbacks = append $fallbacks $m }}
{{- end }}
{{- end }}
{{- end }}
    "{{ $agent }}": {
      "model": "{{ $primary }}",
      "fallback_models": [{{ range $j, $m := $fallbacks }}{{ if $j }}, {{ end }}{"model": "{{ $m }}"}{{ end }}]
      ,"prompt_append": "file://~/.config/opencode/AGENTS.md"
{{- if or (eq $agent "explore") (eq $agent "librarian") (eq $agent "multimodal-looker") }}
      ,"permission": {
        "edit": "deny"{{ if eq $agent "explore" }},
        "bash": "ask"{{ end }}
      }
{{- end }}
{{- if eq $provider "bedrock" }}
{{- if or (eq $agent "oracle") (eq $agent "momus") (eq $agent "prometheus") (eq $agent "metis") }}
      ,"thinking": {"type": "enabled", "budgetTokens": 16000}
{{- end }}
{{- $variantValue := "high" }}
{{- if or (eq $agent "oracle") (eq $agent "momus") }}{{- $variantValue = "max" }}{{- end }}
{{- if eq $tier "fast" }}{{- $variantValue = "medium" }}{{- end }}
{{- if eq $tier "cheap" }}{{- $variantValue = "low" }}{{- end }}
      ,"variant": "{{ $variantValue }}"
{{- end }}
{{- if eq $provider "xiaomi" }}
{{- $variantValue := "high" }}
{{- if eq $tier "fast" }}{{- $variantValue = "medium" }}{{- end }}
{{- if eq $tier "cheap" }}{{- $variantValue = "low" }}{{- end }}
      ,"variant": "{{ $variantValue }}"
{{- end }}
    }{{ if lt $i (sub (len $agents) 1) }},{{ end }}
{{- end }}
  },
  "categories": {
{{- $categories := keys $.opencode.category_tiers | sortAlpha }}
{{- range $i, $cat := $categories }}
{{- $tier := index $.opencode.category_tiers $cat }}
{{- $primary := index (index $.opencode.tiers $provider) $tier }}
{{- $seen := list $primary }}
{{- $fallbacks := list }}
{{- range $t := $tierOrder }}
{{- if ne $t $tier }}
{{- $m := index (index $.opencode.tiers $provider) $t }}
{{- if not (has $m $seen) }}
{{- $seen = append $seen $m }}
{{- $fallbacks = append $fallbacks $m }}
{{- end }}
{{- end }}
{{- end }}
    "{{ $cat }}": {
      "model": "{{ $primary }}",
      "fallback_models": [{{ range $j, $m := $fallbacks }}{{ if $j }}, {{ end }}{"model": "{{ $m }}"}{{ end }}]
    }{{ if lt $i (sub (len $categories) 1) }},{{ end }}
{{- end }}
  },
  "experimental": {
    "disable_omo_env": true,
    "task_system": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "protected_tools": ["task", "todowrite", "todoread", "lsp_rename", "session_read", "session_write", "session_search"],
      "turn_protection": {"enabled": true, "turns": 3}
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [429, 500, 502, 503, 504],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "notify_on_fallback": true
  },
  "notification": {
    "force_enable": true
  }
}
