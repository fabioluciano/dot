{
  "$schema": "https://opencode.ai/config.json",
  "model": "amazon-bedrock/us.anthropic.claude-opus-4-8",
  "small_model": "amazon-bedrock/us.anthropic.claude-haiku-4-5-20251001-v1:0",
  "default_agent": "atlas",
  "formatter": true,
  "lsp": {
    "marksman": {
      "command": [
        "marksman",
        "server"
      ],
      "extensions": [
        ".md",
        ".markdown"
      ]
    }
  },
  "enabled_providers": [
    "xiaomi",
    "amazon-bedrock",
    "openai",
    "github-copilot",
    "opencode",
    "anthropic",
    "google"
  ],
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 6000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "vendor/**"
    ]
  },
  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],
  "provider": {
    "xiaomi": {
      "options": {
        "baseURL": "https://token-plan-sgp.xiaomimimo.com/v1",
        "apiKey": "{env:MIMO_API_KEY}"
      },
      "models": {
        "mimo-v2.5-pro": {},
        "mimo-v2.5-pro-ultraspeed": {},
        "mimo-v2.5": {}
      }
    },
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "gpt-5.5": {},
        "gpt-5.4-mini": {},
        "gpt-5.4-nano": {}
      }
    },
    "opencode": {
      "options": {
        "apiKey": "{env:OPENCODE_API_KEY}"
      },
      "models": {
        "claude-opus-4-7": {},
        "claude-sonnet-4-6": {},
        "gemini-3.1-pro": {},
        "gpt-5.5": {},
        "gpt-5.4-mini": {},
        "gpt-5-nano": {},
        "grok-build-0.1": {},
        "kimi-k2.5": {},
        "glm-5": {},
        "big-pickle": {},
        "minimax-m2.7": {},
        "deepseek-v4-flash-free": {},
        "mimo-v2.5-free": {},
        "nemotron-3-ultra-free": {},
        "north-mini-code-free": {}
      }
    },
    "anthropic": {
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      },
      "models": {
        "claude-opus-4-8": {},
        "claude-sonnet-4-6": {},
        "claude-haiku-4-5": {}
      }
    },
    "amazon-bedrock": {
      "options": {
        "apiKey": "{env:AWS_BEARER_TOKEN_BEDROCK}",
        "region": "us-east-1"
      },
      "models": {
        "us.anthropic.claude-opus-4-8": {},
        "us.anthropic.claude-sonnet-4-6": {},
        "us.anthropic.claude-haiku-4-5-20251001-v1:0": {}
      }
    },
    "google": {
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "variants": {
            "low": { "thinkingLevel": "low" },
            "high": { "thinkingLevel": "high" }
          }
        },
        "antigravity-gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro (Antigravity)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "variants": {
            "low": { "thinkingLevel": "low" },
            "high": { "thinkingLevel": "high" }
          }
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "variants": {
            "minimal": { "thinkingLevel": "minimal" },
            "low": { "thinkingLevel": "low" },
            "medium": { "thinkingLevel": "medium" },
            "high": { "thinkingLevel": "high" }
          }
        },
        "antigravity-claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Antigravity)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        },
        "antigravity-claude-opus-4-6-thinking": {
          "name": "Claude Opus 4.6 Thinking (Antigravity)",
          "limit": { "context": 200000, "output": 64000 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] },
          "variants": {
            "low": { "thinkingConfig": { "thinkingBudget": 8192 } },
            "max": { "thinkingConfig": { "thinkingBudget": 32768 } }
          }
        },
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65536 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        },
        "gemini-3-pro-preview": {
          "name": "Gemini 3 Pro Preview (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        },
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        },
        "gemini-3.1-pro-preview-customtools": {
          "name": "Gemini 3.1 Pro Preview Custom Tools (Gemini CLI)",
          "limit": { "context": 1048576, "output": 65535 },
          "modalities": { "input": ["text", "image", "pdf"], "output": ["text"] }
        }
      }
    }
  },
  "plugin": [
    "context-mode",
    "openrtk",
    "oh-my-openagent",
    "opencode-antigravity-auth@latest",
    "@tarquinen/opencode-dcp@3.1.13",
    "opencode-notify",
    "@slkiser/opencode-quota"
  ],
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "skill": {
      "*": "allow"
    }
  },
  "command": {
    "openspec-init": {
      "description": "Initialize or refresh OpenSpec in the current project",
      "template": "Set up OpenSpec for this repository. If openspec/ does not exist, run `npx -y @fission-ai/openspec@latest init`. If it already exists, run `npx -y @fission-ai/openspec@latest update`. Then summarize the generated or changed files."
    },
    "openspec-propose": {
      "description": "Start an OpenSpec proposal",
      "template": "Use the OpenSpec workflow for this request: $ARGUMENTS. If OpenSpec is not initialized, initialize it first with `npx -y @fission-ai/openspec@latest init`. Create or update the appropriate proposal, design, specs, and tasks under openspec/ before implementation."
    },
    "beads-init": {
      "description": "Initialize Beads issue tracking in the current project",
      "template": "Set up Beads for this repository. First check whether the `bd` command exists. If it is missing, tell me to install it with `brew install beads` or `npm install -g @beads/bd`. If available and .beads/ does not exist, run `bd init`. Then run `bd prime` and summarize the workflow guidance."
    },
    "beads-ready": {
      "description": "Show Beads ready tasks",
      "template": "Use Beads to inspect ready work. Run `bd ready --json` if available, then summarize ready tasks and blockers. If Beads is not initialized, say that `bd init` is needed."
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "timeout": 8000
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 8000
    },
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "timeout": 8000
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "timeout": 10000
    },
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "codebase-memory": {
      "type": "local",
      "command": [
        "codebase-memory-mcp"
      ],
      "enabled": true,
      "timeout": 15000
    }
  }
}
