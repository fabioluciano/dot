{
  "$schema": "https://opencode.ai/config.json",
  "model": "xiaomi/mimo-v2.5",
  "small_model": "xiaomi/mimo-v2.5",
  "default_agent": "atlas",
  "formatter": true,
  "lsp": {
    "marksman": {
      "command": [
        "marksman",
        "server"
      ],
      "extensions": [
        ".md",
        ".markdown"
      ]
    }
  },
  "enabled_providers": [
    "xiaomi",
    "amazon-bedrock",
    "openai",
    "anthropic"
  ],
  "compaction": {
    "auto": true,
    "prune": false,
    "reserved": 6000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "vendor/**"
    ]
  },
  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],
  "provider": {
    "xiaomi": {
      "options": {
        "baseURL": "https://token-plan-sgp.xiaomimimo.com/v1",
        "apiKey": "{env:MIMO_API_KEY}"
      },
      "models": {
        "mimo-v2.5-pro": {},
        "mimo-v2.5": {}
      }
    },
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "gpt-5.5": {},
        "gpt-5.4-mini": {},
        "gpt-5.4-nano": {}
      }
    },
    "anthropic": {
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      },
      "models": {
        "claude-opus-4-8": {},
        "claude-sonnet-4-6": {},
        "claude-haiku-4-5": {}
      }
    },
    "amazon-bedrock": {
      "options": {
        "apiKey": "{env:AWS_BEARER_TOKEN_BEDROCK}",
        "region": "us-east-1"
      },
      "models": {
        "us.anthropic.claude-opus-4-8": {},
        "us.anthropic.claude-sonnet-4-6": {},
        "us.anthropic.claude-haiku-4-5-20251001-v1:0": {}
      }
    }
  },
  "plugin": [
    "context-mode",
    "openrtk",
    "oh-my-openagent",
    "@tarquinen/opencode-dcp@3.1.13",
    "opencode-notify"
  ],
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "skill": {
      "*": "allow"
    }
  },
  "command": {
    "openspec-init": {
      "description": "Initialize or refresh OpenSpec in the current project",
      "template": "Set up OpenSpec for this repository. If openspec/ does not exist, run `npx -y @fission-ai/openspec@latest init`. If it already exists, run `npx -y @fission-ai/openspec@latest update`. Then summarize the generated or changed files."
    },
    "openspec-propose": {
      "description": "Start an OpenSpec proposal",
      "template": "Use the OpenSpec workflow for this request: $ARGUMENTS. If OpenSpec is not initialized, initialize it first with `npx -y @fission-ai/openspec@latest init`. Create or update the appropriate proposal, design, specs, and tasks under openspec/ before implementation."
    },
    "beads-init": {
      "description": "Initialize Beads issue tracking in the current project",
      "template": "Set up Beads for this repository. First check whether the `bd` command exists. If it is missing, tell me to install it with `brew install beads` or `npm install -g @beads/bd`. If available and .beads/ does not exist, run `bd init`. Then run `bd prime` and summarize the workflow guidance."
    },
    "beads-ready": {
      "description": "Show Beads ready tasks",
      "template": "Use Beads to inspect ready work. Run `bd ready --json` if available, then summarize ready tasks and blockers. If Beads is not initialized, say that `bd init` is needed."
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "timeout": 8000
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 8000
    },
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "timeout": 8000
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "timeout": 10000
    },
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true,
      "timeout": 10000
    },
    "codebase-memory": {
      "type": "local",
      "command": [
        "codebase-memory-mcp"
      ],
      "enabled": true,
      "timeout": 15000
    }
  }
}
