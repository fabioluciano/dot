{
  "$schema": "https://opencode.ai/config.json",
  "model": "mimo/mimo-v2.5-pro",
  "small_model": "mimo/mimo-v2.5",
  "default_agent": "atlas",
  "formatter": true,
  "lsp": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "vendor/**"]
  },
  "instructions": ["~/.config/opencode/AGENTS.md"],
  "provider": {
    "mimo": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiMo",
      "options": {
        "baseURL": "https://token-plan-sgp.xiaomimimo.com/v1",
        "apiKey": "{env:MIMO_API_KEY}"
      },
      "models": {
        "mimo-v2.5-pro": {
          "name": "mimo-v2.5-pro",
          "limit": { "context": 1048576, "output": 131072 },
          "modalities": { "input": ["text"], "output": ["text"] }
        },
        "mimo-v2.5": {
          "name": "mimo-v2.5",
          "limit": { "context": 1048576, "output": 131072 },
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "mimo-v2.5-asr": {
          "name": "mimo-v2.5-asr",
          "limit": { "context": 1048576, "output": 131072 },
          "modalities": { "input": ["text", "audio"], "output": ["text"] }
        },
        "mimo-v2.5-tts-voiceclone": {
          "name": "mimo-v2.5-tts-voiceclone",
          "limit": { "context": 1048576, "output": 131072 },
          "modalities": { "input": ["text"], "output": ["audio"] }
        },
        "mimo-v2.5-tts-voicedesign": {
          "name": "mimo-v2.5-tts-voicedesign",
          "limit": { "context": 1048576, "output": 131072 },
          "modalities": { "input": ["text"], "output": ["audio"] }
        },
        "mimo-v2.5-tts": {
          "name": "mimo-v2.5-tts",
          "limit": { "context": 1048576, "output": 131072 },
          "modalities": { "input": ["text"], "output": ["audio"] }
        },
        "mimo-v2-pro": {
          "name": "mimo-v2-pro",
          "limit": { "context": 1048576, "output": 131072 },
          "modalities": { "input": ["text"], "output": ["text"] }
        },
        "mimo-v2-omni": {
          "name": "mimo-v2-omni",
          "limit": { "context": 1048576, "output": 131072 },
          "modalities": { "input": ["text", "image", "audio"], "output": ["text", "audio"] }
        },
        "mimo-v2-tts": {
          "name": "mimo-v2-tts",
          "limit": { "context": 1048576, "output": 131072 },
          "modalities": { "input": ["text"], "output": ["audio"] }
        }
      }
    }
  },
  "plugin": [
    "context-mode",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "ecc-universal",
    "oh-my-openagent"
  ],
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "skill": {
      "*": "allow"
    }
  },
  "command": {
    "openspec-init": {
      "description": "Initialize or refresh OpenSpec in the current project",
      "template": "Set up OpenSpec for this repository. If openspec/ does not exist, run `npx -y @fission-ai/openspec@latest init`. If it already exists, run `npx -y @fission-ai/openspec@latest update`. Then summarize the generated or changed files."
    },
    "openspec-propose": {
      "description": "Start an OpenSpec proposal",
      "template": "Use the OpenSpec workflow for this request: $ARGUMENTS. If OpenSpec is not initialized, initialize it first with `npx -y @fission-ai/openspec@latest init`. Create or update the appropriate proposal, design, specs, and tasks under openspec/ before implementation."
    },
    "beads-init": {
      "description": "Initialize Beads issue tracking in the current project",
      "template": "Set up Beads for this repository. First check whether the `bd` command exists. If it is missing, tell me to install it with `brew install beads` or `npm install -g @beads/bd`. If available and .beads/ does not exist, run `bd init`. Then run `bd prime` and summarize the workflow guidance."
    },
    "beads-ready": {
      "description": "Show Beads ready tasks",
      "template": "Use Beads to inspect ready work. Run `bd ready --json` if available, then summarize ready tasks and blockers. If Beads is not initialized, say that `bd init` is needed."
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true,
      "timeout": 10000
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true,
      "timeout": 15000
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true,
      "timeout": 10000
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true,
      "timeout": 10000
    },
    "fetch": {
      "type": "local",
      "command": ["uvx", "mcp-server-fetch"],
      "enabled": true,
      "timeout": 15000
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "timeout": 10000
    },
    "ruflo": {
      "type": "local",
      "command": ["npx", "-y", "ruflo@latest", "mcp", "start"],
      "enabled": false,
      "timeout": 30000
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      },
      "timeout": 15000
    },
    "codebase-memory": {
      "type": "local",
      "command": ["/Users/fabioluciano/.local/bin/codebase-memory-mcp"],
      "enabled": true,
      "timeout": 30000
    }
  }
}
