# =============================================================================
# Performance Optimizations
# =============================================================================

# Enable profiling (uncomment to debug startup time)
# zmodload zsh/zprof

# Skip global compinit (we run our own, cached, below)
skip_global_compinit=1

# =============================================================================
# Environment Variables (set early)
# =============================================================================

export EDITOR=nvim
export VISUAL=nvim
export PAGER=less
export LANG=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8

export ZSH_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
[[ -d $ZSH_CACHE_DIR/completions ]] || mkdir -p "$ZSH_CACHE_DIR/completions"

# Plugin tunables (read when the bundle is sourced below)
# autosuggestions: suggest from history first, then from completion.
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
# you-should-use: nudge after the command output, not before.
export YSU_MESSAGE_POSITION="after"
# zsh-abbr: version-controlled, seed-once abbreviations file.
export ABBR_USER_ABBREVIATIONS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/zsh-abbr/user-abbreviations"

# =============================================================================
# Plugin Manager - antidote (static bundle)
# =============================================================================
# antidote generates a single, pre-sourced file from .zsh_plugins.txt, so shell
# startup only sources one (zcompiled) file instead of resolving plugins live.

ANTIDOTE_DIR="${ZDOTDIR:-$HOME}/.antidote"
if [[ ! -e $ANTIDOTE_DIR/antidote.zsh ]]; then
    git clone --depth=1 https://github.com/mattmc3/antidote "$ANTIDOTE_DIR"
fi
source "$ANTIDOTE_DIR/antidote.zsh"

# --- Stage 1: completions onto fpath (must run BEFORE compinit) --------------
_zpre_txt="${ZDOTDIR:-$HOME}/.zsh_plugins_pre.txt"
_zpre_zsh="${ZDOTDIR:-$HOME}/.zsh_plugins_pre.zsh"
if [[ ! $_zpre_zsh -nt $_zpre_txt ]]; then
    antidote bundle <"$_zpre_txt" >"$_zpre_zsh"
fi
source "$_zpre_zsh"

# Extra fpath entries (also before compinit).
fpath+=~/.zfunc
{{- if eq .chezmoi.os "darwin" }}
if command -v brew &>/dev/null; then
    BREW_PREFIX="$(brew --prefix)"
    FPATH="${BREW_PREFIX}/share/zsh/site-functions:${FPATH}"
fi
{{- end }}

# =============================================================================
# Completion System (single, cached compinit) — defines `compdef`
# =============================================================================

# Refresh the dump (with security check) at most once every 24h; otherwise load
# the cached dump with -C (skips the slow compaudit + redump).
# NOTE: glob qualifiers do NOT expand inside [[ ]], so the "older than 24h"
# test must collect matches via an array (a real globbing context). Using
# [[ -n ${f}(#qN.mh+24) ]] silently always takes the full path → redump on
# every startup.
autoload -Uz compinit
_zcompdump="${ZDOTDIR:-$HOME}/.zcompdump"
_zcompdump_stale=( ${_zcompdump}(N.mh+24) )
if (( $#_zcompdump_stale )); then
    compinit -d "$_zcompdump"
else
    compinit -C -d "$_zcompdump"
fi
unset _zcompdump_stale
# Compile the dump in the background so the next start is even faster.
{ [[ ! -s ${_zcompdump}.zwc || $_zcompdump -nt ${_zcompdump}.zwc ]] \
    && zcompile -R -- "${_zcompdump}.zwc" "$_zcompdump" 2>/dev/null } &!
unset _zcompdump

# --- Stage 2: remaining plugins (OMZ calls `compdef`; safe now) --------------
# Regenerate (and compile) the static bundle only when the plugin list changes.
_zplugins_txt="${ZDOTDIR:-$HOME}/.zsh_plugins.txt"
_zplugins_zsh="${ZDOTDIR:-$HOME}/.zsh_plugins.zsh"
if [[ ! $_zplugins_zsh -nt $_zplugins_txt ]]; then
    antidote bundle <"$_zplugins_txt" >"$_zplugins_zsh"
    zcompile -R -- "${_zplugins_zsh}.zwc" "$_zplugins_zsh" 2>/dev/null
fi
source "$_zplugins_zsh"
unset _zpre_txt _zpre_zsh _zplugins_txt _zplugins_zsh

# history-substring-search bindings (widgets are loaded by the bundle above)
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
bindkey -M vicmd 'k' history-substring-search-up
bindkey -M vicmd 'j' history-substring-search-down

# =============================================================================
# History Configuration
# =============================================================================

HISTFILE=~/.zsh_history
HISTSIZE=1000000
SAVEHIST=1000000
HISTORY_IGNORE="(ls|cd|pwd|exit|clear|history)*"

setopt EXTENDED_HISTORY      # Write the history file in the ':start:elapsed;command' format.
setopt INC_APPEND_HISTORY    # Write to the history file immediately, not when the shell exits.
setopt SHARE_HISTORY         # Share history between all sessions.
setopt HIST_IGNORE_DUPS      # Do not record an event that was just recorded again.
setopt HIST_IGNORE_ALL_DUPS  # Delete an old recorded event if a new event is a duplicate.
setopt HIST_IGNORE_SPACE     # Do not record an event starting with a space.
setopt HIST_SAVE_NO_DUPS     # Do not write a duplicate event to the history file.
setopt HIST_VERIFY           # Do not execute immediately upon history expansion.

setopt HIST_REDUCE_BLANKS    # Remove superfluous blanks from each command line being added to the history.

# =============================================================================
# Shell Options
# =============================================================================

setopt AUTO_CD               # `foo` ≡ `cd foo` when foo is a directory
setopt INTERACTIVE_COMMENTS  # allow #comments in the interactive shell
setopt NUMERIC_GLOB_SORT     # sort numeric filenames numerically (f2 < f10)
setopt GLOB_DOTS             # let globs match dotfiles without an explicit leading dot

# =============================================================================
# Completion Styles
# =============================================================================

zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*:git-checkout:*' sort false
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
# kubectl: preview the subcommand's help (no-op if the tag doesn't match)
zstyle ':fzf-tab:complete:(kubectl|k):*' fzf-preview 'kubectl $word --help 2>/dev/null | head -300'
# systemctl (Linux): preview unit status
zstyle ':fzf-tab:complete:systemctl-*:*' fzf-preview 'SYSTEMD_COLORS=1 systemctl status $word 2>/dev/null'
zstyle ':fzf-tab:*' switch-group '<' '>'
zstyle ':fzf-tab:*' fzf-command ftb-tmux-popup
zstyle ':fzf-tab:*' popup-pad 80 0

# =============================================================================
# PATH
# =============================================================================

export PATH="${HOME}/.local/bin:${HOME}/.krew/bin:${PATH}"

# =============================================================================
# Tool Integrations
# =============================================================================

# _cache_eval <name> <cmd...>: run <cmd> once and cache its output, re-running
# only when the underlying binary changes. Avoids spawning a subprocess for
# every `tool init`-style integration on each shell startup.
_cache_eval() {
    local name=$1; shift
    local cache="$ZSH_CACHE_DIR/$name.zsh"
    local bin; bin=$(command -v "$1" 2>/dev/null)
    if [[ -n $bin && ( ! -s $cache || $bin -nt $cache ) ]]; then
        "$@" > "$cache" 2>/dev/null
        zcompile -R -- "$cache.zwc" "$cache" 2>/dev/null
    fi
    [[ -s $cache ]] && source "$cache"
}

# _lazyload <cmd> <init>: defer a tool's completion/init until first use.
_lazyload() {
    local cmd=$1 init=$2
    eval "$cmd() { unfunction $cmd; $init; $cmd \"\$@\"; }"
}

# FZF — keybindings + completion (fzf >= 0.48 ships `fzf --zsh`)
if command -v fzf &>/dev/null; then
    if fzf --zsh &>/dev/null; then
        _cache_eval fzf fzf --zsh
    else
{{- if eq .chezmoi.os "linux" }}
{{-   if eq .chezmoi.osRelease.id "arch" }}
        [[ -f /usr/share/fzf/completion.zsh ]]   && source /usr/share/fzf/completion.zsh
        [[ -f /usr/share/fzf/key-bindings.zsh ]] && source /usr/share/fzf/key-bindings.zsh
{{-   else }}
        [[ -f /usr/share/doc/fzf/examples/completion.zsh ]]   && source /usr/share/doc/fzf/examples/completion.zsh
        [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]] && source /usr/share/doc/fzf/examples/key-bindings.zsh
{{-   end }}
{{- end }}
    fi
fi

export FZF_TMUX_OPTS="-p"
export FZF_CTRL_R_OPTS="--reverse --preview 'echo {}' --preview-window down:30:hidden:wrap --bind '?:toggle-preview'"

# Direnv — needed for directory changes
command -v direnv &>/dev/null && _cache_eval direnv direnv hook zsh

# Zoxide — keep builtin cd for real paths, fall back to `z` otherwise
if command -v zoxide &>/dev/null; then
    _cache_eval zoxide zoxide init zsh
    cd() {
        if [[ $# -eq 0 || -d "$1" || "$1" == "." || "$1" == ".." || "$1" == -* ]]; then
            builtin cd "$@"
        else
            z "$@"
        fi
    }
fi

# Starship prompt
command -v starship &>/dev/null && _cache_eval starship starship init zsh

# Mise — runtime/environment manager
command -v mise &>/dev/null && _cache_eval mise mise activate zsh

# Lazy-loaded completions (loaded on first use)
command -v bw    &>/dev/null && _lazyload bw    'eval "$(bw completion --shell zsh)"'
command -v jj    &>/dev/null && _lazyload jj    'source <(jj util completion zsh)'
command -v ngrok &>/dev/null && _lazyload ngrok 'eval "$(ngrok completion)"'
command -v sem   &>/dev/null && _lazyload sem   'eval "$(command sem completions zsh)"'

# Kubectl — lazy load (saves ~200ms on startup), re-alias to kubecolor if present
if command -v kubectl &>/dev/null; then
    kubectl() {
        unfunction kubectl
        source <(command kubectl completion zsh)
        if command -v kubecolor &>/dev/null; then
            alias kubectl=kubecolor
            compdef kubecolor=kubectl
        fi
        kubectl "$@"
    }
fi

# Helm — lazy load
if command -v helm &>/dev/null; then
    helm() {
        unfunction helm
        source <(command helm completion zsh)
        helm "$@"
    }
fi

# =============================================================================
# Aliases
# =============================================================================

# Better defaults
alias du="ncdu --color dark"
alias ls='eza --icons --git'
alias ll='eza -l --icons --git'
alias la='eza -la --icons --git'
alias lt='eza --tree --icons --git'
alias tree='eza --tree --icons --git'
alias l='ll'
alias cat='bat'
alias df='duf'
alias ps='procs'
command -v viddy &>/dev/null && alias watch='viddy'  # modern watch: diff, scroll, history

# Weather - `wttr` for current location, `wttr <city>` for another
wttr() { curl -s "wttr.in/${1:-}" }

# Git shortcuts (ga/gd/gco/glo etc. are provided interactively by forgit)
alias g='git'
alias gs='git status'
alias gc='git commit'
alias gp='git push'
alias gl='git pull'
alias gb='git branch'
alias glog='git log --oneline --graph --decorate'

# Kubernetes shortcuts
alias k='kubectl'
alias kn='kubectl ns'
alias kx='kubectl ctx'
alias kgp='kubectl get pods'
alias kgs='kubectl get svc'
alias kgd='kubectl get deployments'
alias kdp='kubectl describe pod'
alias kl='kubectl logs'
alias kaf='kubectl apply -f'
alias kdel='kubectl delete'

# Editor
alias vim='nvim'
alias vi='nvim'
alias v='nvim'

# Clipboard (Linux only)
{{- if eq .chezmoi.os "linux" }}
if command -v xsel &>/dev/null; then
  alias pbcopy='xsel --clipboard --input'
  alias pbpaste='xsel --clipboard --output'
elif command -v xclip &>/dev/null; then
  alias pbcopy='xclip -selection clipboard'
  alias pbpaste='xclip -selection clipboard -o'
fi
{{- end }}

# System shortcuts
alias reload='exec zsh'
alias zshconfig='nvim ~/.zshrc'
alias cls='clear'

# =============================================================================
# GPG/SSH Configuration
# =============================================================================

if command -v gpgconf &>/dev/null; then
  export GPG_TTY=$(tty)
  export SSH_AUTH_SOCK=$(gpgconf --list-dirs agent-ssh-socket)
  gpgconf --launch gpg-agent 2>/dev/null
fi

# =============================================================================
# OpenCode Provider
# =============================================================================

export OPENCODE_PROVIDER="$(cat "${HOME}/.config/opencode/.active_provider" 2>/dev/null || echo xiaomi)"

# =============================================================================
# Profiling (uncomment together with the zprof line at the top)
# =============================================================================

# zprof
